# ============================================================
# iBuildNew Marketing Dashboard — environment configuration
# ============================================================
#
# Copy this file to `.env.local` and fill in the values below.
# Any variable left blank will cause the dashboard to fall back
# to its mock-data sample for that source, so you can see the UI
# working before every integration is wired up.
#
# How to use:
#   1. Duplicate this file and rename it to `.env.local`
#   2. Paste your credentials next to each variable below
#   3. Restart the dev server (`npm run dev`) after saving
#
# Never commit `.env.local` to a shared repo.
# ============================================================

# ---------- Global behaviour ----------
# Set to "true" to force mock data even if real credentials are present.
# Use this when you want to show the dashboard to someone without
# pulling live numbers.
USE_MOCK_DATA=false

# Currency + locale used for formatting. Do not change unless
# reporting to a non-AUD audience.
CURRENCY=AUD
LOCALE=en-AU

# ---------- Meta Ads (read from Google Sheet) ----------
# Meta spend is pulled from a tab on the WIP spreadsheet rather than
# the Meta API, because there's already a daily auto-refreshed export
# landing there. The tab contains one row per (adset, campaign, date).
#
# The tab must live on the same spreadsheet as the WIP contracts
# (configured via WIP_SHEET_ID below) so one service account covers both.
META_SPEND_SHEET_RANGE='Data - Spend - IBN/HS'!A1:AZ50000

# Optional: comma-separated list of brand values (from the
# "Homeshelf/IBuildNew" column) that should be INCLUDED. Anything else
# is filtered out. Case-insensitive. Leave blank to include every row.
META_SPEND_BRAND_FILTER=IBuildNew,Homeshelf

# ---------- Pipedrive ----------
# Find your token at Settings → Personal preferences → API.
# Domain is the subdomain of your Pipedrive workspace (e.g. `ibuildnew`).
PIPEDRIVE_API_TOKEN=
PIPEDRIVE_DOMAIN=ibuildnew

# Pipeline stage IDs that define a "lead". Referrals come from the
# separate Referrals sheet (see REFERRALS_SHEET_ID below), so only
# PIPEDRIVE_LEAD_STAGE_IDS is required now.
# Settings → Company settings → Pipelines → hover any stage to see its ID.
# Comma-separated — a deal counts as a "lead" if its current stage is in
# this list.
# PIPEDRIVE_REFERRAL_STAGE_IDS is kept for backward compatibility but can
# be left blank — the sheet is the source of truth for referrals.
PIPEDRIVE_LEAD_STAGE_IDS=
PIPEDRIVE_REFERRAL_STAGE_IDS=

# Pipedrive custom field keys (40-character hashes) used to link deals
# to a builder/job number and to an ad-campaign identifier.
# Leave blank if you don't have these fields set up yet — filtering
# by builder/campaign will be disabled.
PIPEDRIVE_JOB_NUMBER_FIELD=
PIPEDRIVE_CAMPAIGN_FIELD=

# ---------- Google Sheets (WIP sheet) ----------
# 1. Create a Google Cloud service account (one-time).
# 2. Download the JSON key file.
# 3. Share the WIP sheet AND the Referrals sheet (further down) with the
#    service account email (Viewer on each).
# 4. Provide the credentials to the app using EXACTLY ONE of the options
#    below.
# 5. The sheet ID is the long string in the sheet's URL between /d/ and /edit.
#
# OPTION A — Local development (default)
# Save the key file at ./credentials/google-service-account.json and point
# the variable at that path. The credentials/ folder is gitignored.
GOOGLE_SERVICE_ACCOUNT_FILE=./credentials/google-service-account.json
#
# OPTION B — Vercel / production deploy
# Paste the full contents of the JSON key file into GOOGLE_SERVICE_ACCOUNT_JSON
# as a single value. Vercel's env var UI handles the multiline private_key
# fine. If both options are set, JSON takes precedence.
# GOOGLE_SERVICE_ACCOUNT_JSON=
WIP_SHEET_ID=
# Range is an A1 reference. Tab names with spaces must be wrapped in single
# quotes, e.g. `'WIP - Consolidated'!A1:T1000`. Use enough columns to include
# every header the dashboard needs (Job #, Project, RPL, Total Lead Target,
# Campaign Live Date, Campaign End Date, Status).
WIP_SHEET_RANGE='WIP - Consolidated'!A1:T1000

# Optional: comma-separated list of STATUS cell values that count as
# "live/active". Any row with a different STATUS is ignored. Leave blank
# to include every row regardless of STATUS.
WIP_SHEET_STATUS_VALUES=Live

# ---------- Google Sheets (Referrals sheet) ----------
# Referrals live on a SEPARATE spreadsheet from the WIP. Share this
# spreadsheet with the same service account email (Viewer) — the service
# account must have access to both spreadsheets for the dashboard to go live.
#
# Expected columns on the "All Contacts" tab (column letters):
#   Column I  → Attributed Date       (the referral date — used for windowing)
#   Column W  → Job Number             (attributes referral to a WIP contract)
#   Column X  → RPL                    (per-referral revenue — drives ROMS)
#   Column Y  → Lead Return Reason     (ONLY count rows where this cell is blank)
REFERRALS_SHEET_ID=
REFERRALS_SHEET_RANGE='All Contacts'!A1:AS100000
